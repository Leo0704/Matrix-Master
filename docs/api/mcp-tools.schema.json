{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matrix.local/schemas/mcp-tools.schema.json",
  "title": "MCP Tools Schema",
  "description": "Agent 可调用的工具集合的 JSON Schema 定义。所有工具的输入输出必须符合此 schema，工具调用经限速器后转发到 APK。",
  "version": "0.1.0",
  "type": "object",
  "definitions": {
    "OkResponse": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "data": { "type": "object" }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "required": ["ok", "error"],
      "properties": {
        "ok": { "const": false },
        "error": {
          "type": "object",
          "required": ["code", "message", "retryable"],
          "properties": {
            "code": {
              "type": "string",
              "enum": [
                "DEVICE_OFFLINE",
                "APP_NOT_FOUND",
                "SELECTOR_NOT_FOUND",
                "TIMEOUT",
                "IME_ERROR",
                "DRAFT_FAILED",
                "UPLOAD_FAILED",
                "RISK_BLOCKED",
                "RATE_LIMITED",
                "PARSE_FAILED",
                "INVALID_PARAMS",
                "INTERNAL_ERROR"
              ]
            },
            "message": { "type": "string" },
            "retryable": { "type": "boolean" }
          }
        }
      }
    },
    "RequestId": {
      "type": "string",
      "format": "uuid",
      "description": "幂等 key，重试不重复执行"
    },
    "DeviceId": {
      "type": "string",
      "format": "uuid"
    },
    "Coord": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 }
      }
    },
    "Selector": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["resource_id", "content_desc", "text", "xpath"]
        },
        "value": { "type": "string" }
      }
    },
    "Target": {
      "oneOf": [
        {
          "type": "object",
          "required": ["coord"],
          "properties": {
            "coord": { "$ref": "#/definitions/Coord" }
          }
        },
        {
          "type": "object",
          "required": ["selector"],
          "properties": {
            "selector": { "$ref": "#/definitions/Selector" },
            "fallback_vlm": { "type": "boolean", "default": false }
          }
        }
      ]
    }
  },
  "tools": {
    "device_status": {
      "description": "查询设备状态。在执行任何操作前调用，确认设备在线。",
      "input": {
        "type": "object",
        "required": ["device_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" }
        }
      },
      "output": {
        "type": "object",
        "required": ["ok", "data"],
        "properties": {
          "ok": { "type": "boolean" },
          "data": {
            "type": "object",
            "required": ["online", "busy", "app", "battery", "network"],
            "properties": {
              "online": { "type": "boolean" },
              "busy": { "type": "boolean" },
              "app": { "type": "string" },
              "battery": { "type": "integer", "minimum": 0, "maximum": 100 },
              "network": { "type": "string", "enum": ["4G", "5G", "none"] },
              "signal_dbm": { "type": "integer" },
              "tailscale_state": { "type": "string" }
            }
          }
        }
      },
      "idempotent": true,
      "side_effects": []
    },
    "device_open_app": {
      "description": "打开指定 App。打开 XHS 前必须先调用此工具。",
      "input": {
        "type": "object",
        "required": ["device_id", "package", "request_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "package": { "type": "string" },
          "request_id": { "$ref": "#/definitions/RequestId" }
        }
      },
      "output": { "$ref": "#/definitions/OkResponse" },
      "idempotent": false,
      "side_effects": ["changes_foreground_app"]
    },
    "device_screenshot": {
      "description": "截屏。用于 VLM 读屏或事后排查。",
      "input": {
        "type": "object",
        "required": ["device_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "region": {
            "type": "string",
            "description": "可选，格式 x,y,w,h"
          }
        }
      },
      "output": {
        "type": "object",
        "required": ["ok", "data"],
        "properties": {
          "ok": { "type": "boolean" },
          "data": {
            "type": "object",
            "required": ["image_b64", "ts"],
            "properties": {
              "image_b64": { "type": "string" },
              "ts": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "idempotent": true,
      "side_effects": []
    },
    "device_tap": {
      "description": "点击。可按坐标或选择器。",
      "input": {
        "type": "object",
        "required": ["device_id", "target", "request_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "target": { "$ref": "#/definitions/Target" },
          "request_id": { "$ref": "#/definitions/RequestId" }
        }
      },
      "output": { "$ref": "#/definitions/OkResponse" },
      "idempotent": false,
      "side_effects": ["ui_state_change"]
    },
    "device_input": {
      "description": "在当前焦点输入框输入文本。",
      "input": {
        "type": "object",
        "required": ["device_id", "text", "request_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "text": { "type": "string" },
          "request_id": { "$ref": "#/definitions/RequestId" }
        }
      },
      "output": { "$ref": "#/definitions/OkResponse" },
      "idempotent": false,
      "side_effects": ["ui_state_change"]
    },
    "device_swipe": {
      "description": "滑动。",
      "input": {
        "type": "object",
        "required": ["device_id", "from", "to", "request_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "from": { "$ref": "#/definitions/Coord" },
          "to": { "$ref": "#/definitions/Coord" },
          "duration_ms": { "type": "integer", "default": 300 },
          "request_id": { "$ref": "#/definitions/RequestId" }
        }
      },
      "output": { "$ref": "#/definitions/OkResponse" },
      "idempotent": false,
      "side_effects": ["ui_state_change"]
    },
    "device_publish": {
      "description": "发布笔记。端到端封装：填标题、正文、上传图片、加标签、点击发布。",
      "input": {
        "type": "object",
        "required": ["device_id", "note", "request_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "note": {
            "type": "object",
            "required": ["title", "content", "images", "tags"],
            "properties": {
              "title": { "type": "string", "maxLength": 64 },
              "content": { "type": "string", "maxLength": 2000 },
              "images": {
                "type": "array",
                "items": { "type": "string", "format": "uri" }
              },
              "tags": {
                "type": "array",
                "items": { "type": "string" },
                "maxItems": 10
              },
              "visibility": {
                "type": "string",
                "enum": ["public", "friends", "private"],
                "default": "public"
              }
            }
          },
          "request_id": { "$ref": "#/definitions/RequestId" }
        }
      },
      "output": {
        "type": "object",
        "required": ["ok", "data"],
        "properties": {
          "ok": { "type": "boolean" },
          "data": {
            "type": "object",
            "required": ["platform_note_id", "url"],
            "properties": {
              "platform_note_id": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      },
      "idempotent": true,
      "side_effects": ["external_publish"],
      "errors": {
        "DRAFT_FAILED": "草稿保存失败，可能选择器失效或内容含违禁词",
        "UPLOAD_FAILED": "图片上传失败",
        "RISK_BLOCKED": "触发平台风控，账号暂停"
      }
    },
    "device_interact": {
      "description": "互动操作：点赞 / 评论 / 关注 / 收藏 / 分享。",
      "input": {
        "type": "object",
        "required": ["device_id", "action", "target", "request_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "action": {
            "type": "string",
            "enum": ["like", "comment", "follow", "collect", "share"]
          },
          "target": {
            "type": "object",
            "oneOf": [
              {
                "required": ["note_id"],
                "properties": {
                  "note_id": { "type": "string" }
                }
              },
              {
                "required": ["user_id"],
                "properties": {
                  "user_id": { "type": "string" }
                }
              }
            ]
          },
          "content": {
            "type": "string",
            "description": "评论内容（仅 action=comment）"
          },
          "request_id": { "$ref": "#/definitions/RequestId" }
        }
      },
      "output": { "$ref": "#/definitions/OkResponse" },
      "idempotent": true,
      "side_effects": ["external_interaction"]
    },
    "device_collect": {
      "description": "回采数据：当前账号 / 笔记的 metrics。",
      "input": {
        "type": "object",
        "required": ["device_id", "scope", "request_id"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "scope": {
            "type": "string",
            "enum": ["recent_24h", "recent_7d", "all"]
          },
          "request_id": { "$ref": "#/definitions/RequestId" }
        }
      },
      "output": {
        "type": "object",
        "required": ["ok", "data"],
        "properties": {
          "ok": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "metrics": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "note_id": { "type": "string" },
                    "views": { "type": "integer" },
                    "likes": { "type": "integer" },
                    "collects": { "type": "integer" },
                    "comments": { "type": "integer" },
                    "follows_gained": { "type": "integer" },
                    "ts": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      },
      "idempotent": true,
      "side_effects": []
    },
    "device_wait_for": {
      "description": "等待界面满足 predicate。",
      "input": {
        "type": "object",
        "required": ["device_id", "predicate", "timeout"],
        "properties": {
          "device_id": { "$ref": "#/definitions/DeviceId" },
          "predicate": {
            "type": "object",
            "description": "等待条件，如 {selector: {...}} 或 {text: '发布成功'}",
            "properties": {
              "selector": { "$ref": "#/definitions/Selector" },
              "text": { "type": "string" }
            }
          },
          "timeout": { "type": "integer", "description": "毫秒" }
        }
      },
      "output": {
        "type": "object",
        "required": ["ok"],
        "properties": {
          "ok": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "matched": { "type": "boolean" },
              "snapshot": { "type": "string", "description": "等待结束时的截图 base64" }
            }
          }
        }
      },
      "idempotent": true,
      "side_effects": []
    }
  }
}
