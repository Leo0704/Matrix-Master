# === Matrix Master 后端配置模板 ===
# 复制本文件为 .env 并填值；.env 已在 .gitignore
#
# 生成 MATRIX_API_SECRET（32 字节十六进制）：
#   openssl rand -hex 32
#
# DATABASE_URL 走 docker compose 时用：
#   postgresql+asyncpg://matrix:${POSTGRES_PASSWORD}@postgres:5432/matrix

# --- 必填（生产 fail-fast，未设启动报错）---
DATABASE_URL=postgresql+asyncpg://matrix:CHANGE_ME@postgres:5432/matrix
# 网页控制台访问密码。留空：首次启动自动生成并写入 backend/.api_secret
# （启动日志会打印一次）；自己定：openssl rand -hex 32
MATRIX_API_SECRET=

# --- 设备 HMAC 密钥信封加密（选填）---
# 留空：首次启动自动生成主密钥并写入 backend/.secret_box_key（chmod 600）。
# 该文件务必纳入备份、切勿提交 git——丢失则已加密 secret 不可恢复，
# 对应设备重新配对即可自愈。自己定：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MATRIX_SECRET_BOX_KEY=

# --- LLM providers（按需填；未填的 provider 不可用）---
OPENAI_API_KEY=                            # OpenAI 兼容 key（硅基流动等）
OPENAI_BASE_URL=                           # 如 https://api.openai.com/v1 或你的中转地址
MINIMAX_API_KEY=

# --- LLM 路由默认值（老板配啥填啥，留空走系统默认）---
MATRIX_LLM_PROVIDER=                     # anthropic|openai|deepseek|tongyi|glm|doubao|minimax
MATRIX_LLM_MODEL=                         # 留空走 provider 默认模型

# --- 图像生成（不配就返回占位图）---
MATRIX_IMAGE_PROVIDER=                   # in_memory|tongyi_wanxiang|zhipu_cogview|doubao_seedream|MiniMax_image_gen
DASHSCOPE_BASE_URL=
DOUBAO_BASE_URL=
MINIMAX_BASE_URL=                         # 默认 https://api.minimaxi.com

# --- Tailscale / Headscale ---
TS_API_URL=
TS_API_KEY=

# --- 公网 HTTPS（Caddy 生产入口）---
MATRIX_DOMAIN=                # 如 matrix.example.com，DNS A 记录指向服务器
TLS_EMAIL=                    # Let's Encrypt 账号邮箱

# --- 监控 ---
OTLP_ENDPOINT=